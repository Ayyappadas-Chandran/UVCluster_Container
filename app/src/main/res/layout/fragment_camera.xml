<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.features.controls.advanceFeatures.camera.CameraFragment">

    <com.suprajit.uvcluster.ui.customWidget.BrutalTypeTextView
        android:id="@+id/tvCamera"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="22dp"
        android:text="@string/camera"
        android:textColor="@color/unSelected"
        android:textFontWeight="400"
        android:textSize="24sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/llCamera"
        android:layout_width="628dp"
        android:layout_height="80dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_stroke"
        android:orientation="horizontal"
        android:weightSum="2"
        app:layout_constraintStart_toStartOf="@id/tvCamera"
        app:layout_constraintTop_toBottomOf="@id/tvCamera">

        <com.suprajit.uvcluster.ui.customWidget.BrutalTypeTextView
            android:id="@+id/tvCameraOn"
            android:layout_width="306dp"
            android:layout_height="match_parent"
            android:layout_margin="8dp"
            android:layout_weight="1"
            android:background="@color/activeSelectionRed"
            android:gravity="center"
            android:text="@string/on"
            android:textColor="@color/white"
            android:textFontWeight="500"
            android:textSize="24sp" />

        <ImageView
            android:id="@+id/ivCameraOnSelected"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:contentDescription="@string/on_selected"
            android:src="@drawable/ic_selection"
            android:visibility="visible" />


        <ImageView
            android:id="@+id/ivCameraOffSelected"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:contentDescription="@string/off_selected"
            android:rotation="180"
            android:src="@drawable/ic_selection"
            android:visibility="invisible" />

        <com.suprajit.uvcluster.ui.customWidget.BrutalTypeTextView
            android:id="@+id/tvCameraOff"
            android:layout_width="306dp"
            android:layout_height="match_parent"
            android:layout_gravity="center_vertical"
            android:layout_margin="8dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/off"
            android:textColor="@color/unSelected"
            android:textFontWeight="500"
            android:textSize="24sp" />
    </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="628dp"
        android:layout_height="217dp"
        android:id="@+id/clCamera"
        android:layout_marginTop="32dp"
        android:background="@drawable/bg_stroke"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="@id/llCamera"
        app:layout_constraintTop_toBottomOf="@id/llCamera">

        <ImageView
            android:id="@+id/ivCamera"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="24dp"
            android:src="@drawable/ic_camera"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.suprajit.uvcluster.ui.customWidget.BrutalTypeTextView
            android:id="@+id/tvCamera2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Camera"
            android:textColor="@color/greyMediumLight"
            android:textFontWeight="500"
            android:textSize="20sp"
            android:layout_marginTop="4dp"
            app:layout_constraintStart_toStartOf="@id/ivCamera"
            app:layout_constraintTop_toBottomOf="@id/ivCamera" />

        <com.suprajit.uvcluster.ui.customWidget.BrutalTypeTextView
            android:id="@+id/tvMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Record rides. Capture snaps."
            android:textColor="@color/unSelected"
            android:textFontWeight="400"
            android:textSize="16sp"
            app:layout_constraintStart_toStartOf="@id/ivCamera"
            app:layout_constraintTop_toBottomOf="@id/tvCamera2" />

        <LinearLayout
            android:layout_width="612dp"
            android:layout_height="64dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_stroke"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvMessage">

            <com.suprajit.uvcluster.ui.customWidget.BrutalTypeTextView
                android:id="@+id/tvEnter"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:background="@color/activeSelectionRed"
                android:gravity="center"
                android:padding="8dp"
                android:text="Enter Camera"
                android:textColor="@color/lightGrey"
                android:textSize="22sp" />

        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
