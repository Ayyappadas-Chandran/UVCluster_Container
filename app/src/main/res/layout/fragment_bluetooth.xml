<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.features.settings.bluetooth.BluetoothFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clBluetooth"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.suprajit.uvcluster.ui.customWidget.BrutalTypeTextView
            android:id="@+id/tvBluetooth"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="22dp"
            android:textFontWeight="400"
            android:text="@string/bluetooth"
            android:textColor="@color/unSelectedTitle"
            android:textSize="24sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />


        <LinearLayout
            android:id="@+id/llBluetooth"
            android:layout_width="628dp"
            android:layout_height="80dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_stroke"
            android:orientation="horizontal"
            android:weightSum="2"
            app:layout_constraintStart_toStartOf="@id/tvBluetooth"
            app:layout_constraintTop_toBottomOf="@id/tvBluetooth">

            <com.suprajit.uvcluster.ui.customWidget.BrutalTypeTextView
                android:id="@+id/tvBluetoothOn"
                android:layout_width="306dp"
                android:layout_height="match_parent"
                android:layout_margin="8dp"
                android:layout_weight="1"
                android:textFontWeight="500"
                android:background="@color/backgroundDeselected"
                android:gravity="center"
                android:text="@string/on"
                android:textColor="@color/unSelected"
                android:textSize="24sp" />

            <ImageView
                android:id="@+id/ivBluetoothOnSelected"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:contentDescription="@string/on_selected"
                android:src="@drawable/ic_selection"
                android:visibility="invisible" />

            <ImageView
                android:id="@+id/ivBluetoothOffSelected"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:contentDescription="@string/off_selected"
                android:rotation="180"
                android:src="@drawable/ic_selection"
                android:visibility="invisible" />

            <com.suprajit.uvcluster.ui.customWidget.BrutalTypeTextView
                android:id="@+id/tvBluetoothOff"
                android:layout_width="306dp"
                android:layout_height="match_parent"
                android:layout_gravity="center_vertical"
                android:layout_margin="8dp"
                android:textFontWeight="500"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/off"
                android:textColor="@color/unSelected"
                android:textSize="24sp" />
        </LinearLayout>

        <com.suprajit.uvcluster.ui.customWidget.BrutalTypeTextView
            android:id="@+id/tvDiscoverable"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/discoverable"
            android:textAllCaps="true"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textFontWeight="400"
            app:layout_constraintBottom_toBottomOf="@id/tvBluetooth"
            app:layout_constraintEnd_toEndOf="@id/llBluetooth"
            app:layout_constraintTop_toTopOf="@id/tvBluetooth" />

        <com.suprajit.uvcluster.ui.customWidget.BrutalTypeTextView
            android:id="@+id/tvPairedDevices"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="@string/paired_devices"
            android:textColor="@color/unSelectedTitle"
            android:textSize="24sp"
            android:visibility="gone"
            android:textFontWeight="400"
            app:layout_constraintStart_toStartOf="@id/tvBluetooth"
            app:layout_constraintTop_toBottomOf="@id/llBluetooth" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/clPairedDevices"
            android:layout_width="628dp"
            android:layout_height="80dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_stroke"
            android:padding="8dp"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="@id/tvBluetooth"
            app:layout_constraintTop_toBottomOf="@id/tvPairedDevices">

            <com.suprajit.uvcluster.ui.customWidget.BrutalTypeTextView
                android:id="@+id/tvBluetoothName"
                android:layout_width="540dp"
                android:layout_height="64dp"
                android:background="@color/white"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="0dp"
                android:textFontWeight="500"
                android:textColor="@color/black"
                android:textSize="24sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="iPhone 13" />

            <ImageView
                android:id="@+id/ivDelete"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@color/white"
                android:contentDescription="@string/delete_icon"
                android:padding="20dp"
                android:src="@drawable/ic_delete"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>


        <com.suprajit.uvcluster.ui.customWidget.SairaRegularTextView
            android:id="@+id/tvAvailableDevices"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="@string/available_devices"
            android:textColor="@color/unSelectedTitle"
            android:textSize="24sp"
            android:visibility="visible"
            app:layout_constraintStart_toStartOf="@id/tvBluetooth"
            app:layout_constraintTop_toBottomOf="@id/clPairedDevices" />

        <ProgressBar
            android:id="@+id/pbAvailableDevices"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminateTint="@color/unSelectedTitle"
            app:layout_constraintBottom_toBottomOf="@id/tvAvailableDevices"
            app:layout_constraintEnd_toEndOf="@id/rvAvailableDevices"
            app:layout_constraintTop_toTopOf="@id/tvAvailableDevices" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvAvailableDevices"
            android:layout_width="556dp"
            android:layout_height="500dp"
            android:layout_marginTop="16dp"
            android:visibility="visible"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="@id/tvAvailableDevices"
            app:layout_constraintTop_toBottomOf="@id/tvAvailableDevices" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
