<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    tools:context=".ui.features.MusicFragment">

    <ImageView
        android:id="@+id/bgTopBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="@string/top_bar"
        android:src="@drawable/bg_setting_top_bar"
        android:visibility="invisible"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.suprajit.uvcluster.ui.customWidget.SfProTextView
        android:id="@+id/tvBack"
        android:layout_width="80dp"
        android:layout_height="26dp"
        android:layout_marginEnd="20dp"
        android:drawableEnd="@drawable/ic_back"
        android:text="@string/back"
        android:textFontWeight="400"
        android:textColor="@color/white"
        android:textSize="20sp"
        app:layout_constraintBottom_toBottomOf="@id/bgTopBar"
        app:layout_constraintEnd_toEndOf="@+id/bgTopBar"
        app:layout_constraintTop_toTopOf="@id/bgTopBar" />




    <ImageView
        android:id="@+id/bgMusic"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="@string/music_background_image"
        android:src="@drawable/bg_music"
        app:layout_constraintEnd_toEndOf="@id/bgTopBar"
        app:layout_constraintHorizontal_bias="0.44"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.suprajit.uvcluster.ui.customWidget.BrutalTypeTextView
        android:id="@+id/tvMusic"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:drawableStart="@drawable/ic_music"
        android:drawablePadding="4dp"
        android:text="@string/media"
        android:textAllCaps="true"
        android:textColor="@color/lockdownRed"
        android:textSize="24sp"
        app:layout_constraintEnd_toEndOf="@id/bgTopBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


    <SeekBar
        android:id="@+id/sbSong"
        android:layout_width="774dp"
        android:layout_height="102dp"
        android:max="100"
        android:paddingStart="40dp"
        android:paddingTop="50dp"
        android:paddingEnd="40dp"
        android:paddingBottom="50dp"
        android:progress="80"
        android:progressDrawable="@drawable/bg_progress_music"
        android:splitTrack="false"
        android:thumb="@drawable/thumb_music"
        app:layout_constraintBottom_toBottomOf="@id/bgMusic"
        app:layout_constraintEnd_toEndOf="@id/bgTopBar"
        app:layout_constraintStart_toStartOf="parent" />

    <com.suprajit.uvcluster.ui.customWidget.BrutalTypeTextView
        android:id="@+id/tvCurrentTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="-20dp"
        tools:text="02:50"
        android:textColor="@color/lightGrey"
        app:layout_constraintStart_toStartOf="@id/sbSong"
        app:layout_constraintTop_toBottomOf="@id/sbSong" />

    <com.suprajit.uvcluster.ui.customWidget.BrutalTypeTextView
        android:id="@+id/tvTotalTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:text="04:30"
        android:textColor="@color/lightGrey"
        app:layout_constraintBottom_toBottomOf="@id/tvCurrentTime"
        app:layout_constraintEnd_toEndOf="@id/sbSong"
        app:layout_constraintTop_toTopOf="@id/tvCurrentTime" />

    <ImageView
        android:id="@+id/ivVolume"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="68dp"
        android:contentDescription="@string/volume_icon"
        android:src="@drawable/ic_volume"
        app:layout_constraintBottom_toBottomOf="@id/sbSong"
        app:layout_constraintStart_toEndOf="@id/sbSong"
        app:layout_constraintTop_toTopOf="@id/sbSong" />

    <FrameLayout
        android:id="@+id/flVolume"
        android:layout_width="102dp"
        android:layout_height="329dp"
        android:layout_marginBottom="6dp"
        app:layout_constraintBottom_toTopOf="@id/ivVolume"
        app:layout_constraintEnd_toEndOf="@id/ivVolume"
        app:layout_constraintStart_toStartOf="@id/ivVolume">

        <SeekBar
            android:id="@+id/sbVolume"
            android:layout_width="329dp"
            android:layout_height="102dp"
            android:layout_gravity="center"
            android:max="100"
            android:paddingStart="40dp"
            android:paddingTop="50dp"
            android:paddingEnd="40dp"
            android:paddingBottom="50dp"
            android:progress="50"
            android:progressTint="@color/white"
            android:rotation="270"
            android:splitTrack="false"
            android:thumb="@drawable/thumb_volume" />
    </FrameLayout>

    <ImageView
        android:id="@+id/ivPlayPause"
        android:layout_width="298dp"
        android:layout_height="298dp"
        android:contentDescription="@string/play_pause_icon"
        android:src="@drawable/ic_play"
        android:visibility="invisible"
        app:layout_constraintBottom_toBottomOf="@id/bgMusic"
        app:layout_constraintEnd_toEndOf="@id/bgMusic"
        app:layout_constraintStart_toStartOf="@id/bgMusic"
        app:layout_constraintTop_toTopOf="@id/bgMusic" />

    <ImageView
        android:id="@+id/ivForward"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="153dp"
        android:layout_marginTop="174dp"
        android:layout_marginEnd="182dp"
        android:contentDescription="@string/forward_icon"
        android:src="@drawable/ic_forward"
        android:visibility="invisible"
        app:layout_constraintEnd_toEndOf="@id/bgTopBar"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/ivBackward"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="180dp"
        android:layout_marginTop="174dp"
        android:layout_marginEnd="164dp"
        android:contentDescription="@string/backward_icon"
        android:src="@drawable/ic_backward"
        android:visibility="invisible"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.suprajit.uvcluster.ui.customWidget.InterTextView
        android:id="@+id/tvSongName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="40dp"
        tools:text="Blinding Lights"
        android:textAllCaps="true"
        android:textColor="@color/lightGrey"
        android:textSize="24sp"
        app:layout_constraintBottom_toTopOf="@id/sbSong"
        app:layout_constraintStart_toStartOf="@id/sbSong" />

    <com.suprajit.uvcluster.ui.customWidget.BrutalTypeTextView
        android:id="@+id/tvAlbumName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        tools:text="The Weekend"
        android:textAllCaps="true"
        android:textColor="@color/activeSelectionRed"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="@id/tvSongName"
        app:layout_constraintTop_toBottomOf="@id/tvSongName" />

</androidx.constraintlayout.widget.ConstraintLayout>