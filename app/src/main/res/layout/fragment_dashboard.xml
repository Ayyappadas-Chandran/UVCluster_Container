        app:layout_constraintBottom_toBottomOf="@id/tvRegenValue"
        app:layout_constraintStart_toEndOf="@id/tvRegenValue"
        app:layout_constraintTop_toTopOf="@id/tvRegenValue" />

    <LinearLayout
        android:id="@+id/llRegenLevel4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:orientation="horizontal"
        android:visibility="invisible"
        app:layout_constraintBottom_toBottomOf="@id/tvRegenValue"
        app:layout_constraintStart_toEndOf="@id/tvRegenValue"
        app:layout_constraintTop_toTopOf="@id/tvRegenValue">

