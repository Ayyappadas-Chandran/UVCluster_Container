        app:layout_constraintTop_toTopOf="parent" />

    <com.suprajit.uvcluster.ui.customWidget.SairaRegularTextView
        android:id="@+id/tvOdoValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0"
        android:textColor="?attr/appTextColor"
        android:textFontWeight="400"
        android:textSize="30.76sp"
        app:layout_constraintStart_toStartOf="@id/tvOdoLabel"
