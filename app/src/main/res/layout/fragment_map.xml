<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MapFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clMapWithoutBallistic"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/image_map"
        android:visibility="gone">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cvSpeed"
            android:layout_width="120dp"
            android:layout_height="90dp"
            android:layout_marginStart="18dp"
            android:layout_marginTop="13.47dp"
            app:cardBackgroundColor="@color/blackTransparent"
            app:cardCornerRadius="8dp"
            app:cardElevation="6dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <com.suprajit.uvcluster.ui.customWidget.SairaRegularTextView
                    android:id="@+id/tvSpeed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="19dp"
                    android:text="90"
                    android:textColor="@color/white"
                    android:textSize="36sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.suprajit.uvcluster.ui.customWidget.SairaRegularTextView
                    android:id="@+id/tvSpeedUnit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_marginBottom="6dp"
                    android:text="km/h"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    app:layout_constraintBottom_toBottomOf="@id/tvSpeed"
                    app:layout_constraintStart_toEndOf="@id/tvSpeed"
                    app:textAllCaps="false" />

                <com.suprajit.uvcluster.ui.customWidget.SairaRegularTextView
                    android:id="@+id/tvSpeedLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="-4dp"
                    android:text="Speed"
                    android:textAllCaps="true"
                    android:textColor="#AAFFFFFF"
                    android:textSize="15sp"
                    app:layout_constraintStart_toStartOf="@id/tvSpeed"
                    app:layout_constraintTop_toBottomOf="@id/tvSpeed" />
            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:src="@drawable/image_speed_map"
            android:visibility="invisible"
            app:layout_constraintStart_toEndOf="@id/cvSpeed"
            app:layout_constraintTop_toTopOf="@id/cvSpeed" />

        <ImageView
            android:id="@+id/ivCurrentPosition"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_manuver_position"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />


        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cvRange"
            android:layout_width="120dp"
            android:layout_height="90dp"
            android:layout_marginStart="887dp"
            android:layout_marginTop="13.47dp"
            app:cardBackgroundColor="@color/blackTransparent"
            app:cardCornerRadius="8dp"
            app:cardElevation="6dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <com.suprajit.uvcluster.ui.customWidget.SairaRegularTextView
                    android:id="@+id/tvRange"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="19dp"
                    android:text="120"
                    android:textColor="@color/white"
                    android:textSize="36sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.suprajit.uvcluster.ui.customWidget.SairaRegularTextView
                    android:id="@+id/tvRangeUnit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_marginBottom="6dp"
                    android:text="km"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    app:layout_constraintBottom_toBottomOf="@id/tvRange"
                    app:layout_constraintStart_toEndOf="@id/tvRange"
                    app:textAllCaps="false" />

                <com.suprajit.uvcluster.ui.customWidget.SairaRegularTextView
                    android:id="@+id/tvRangeLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="-4dp"
                    android:text="Range"
                    android:textAllCaps="true"
                    android:textColor="#AAFFFFFF"
                    android:textSize="15sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvRange" />
            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cvOdo"
            android:layout_width="137dp"
            android:layout_height="50dp"
            android:layout_marginTop="13.47dp"
            app:cardBackgroundColor="@color/blackTransparent"
            app:cardCornerRadius="8dp"
            app:cardElevation="6dp"
            app:layout_constraintEnd_toStartOf="@id/cvRange"
            app:layout_constraintStart_toEndOf="@id/cvSpeed"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <com.suprajit.uvcluster.ui.customWidget.SairaRegularTextView
                    android:id="@+id/tvOdo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="30dp"
                    android:layout_marginTop="4dp"
                    android:text="100000"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.suprajit.uvcluster.ui.customWidget.SairaRegularTextView
                    android:id="@+id/tvOdoUnit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="km"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    app:layout_constraintBottom_toBottomOf="@id/tvOdo"
                    app:layout_constraintStart_toEndOf="@id/tvOdo"
                    app:layout_constraintTop_toTopOf="@id/tvOdo" />

                <com.suprajit.uvcluster.ui.customWidget.SairaRegularTextView
                    android:id="@+id/tvOdoLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="-6dp"
                    android:text="Odo"
                    android:textAllCaps="true"
                    android:textColor="#AAFFFFFF"
                    android:textSize="15sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvOdo" />
            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cvTbt"
            android:layout_width="570dp"
            android:layout_height="90dp"
            android:layout_marginTop="409dp"
            app:cardBackgroundColor="@color/blackTransparent"
            app:layout_constraintEnd_toEndOf="@id/cvOdo"
            app:layout_constraintStart_toStartOf="@id/cvOdo"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/ivManeuver"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="31dp"
                    android:src="@drawable/ic_u_turn"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.suprajit.uvcluster.ui.customWidget.SairaRegularTextView
                    android:id="@+id/tvDistance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="15dp"
                    android:layout_marginTop="-10dp"
                    android:text="2.3 km"
                    android:textAllCaps="false"
                    android:textColor="@color/GlowBlue"
                    android:textFontWeight="500"
                    android:textSize="24sp"
                    app:layout_constraintStart_toEndOf="@id/ivManeuver"
                    app:layout_constraintTop_toTopOf="@id/ivManeuver"
                    app:textAllCaps="false" />

                <com.suprajit.uvcluster.ui.customWidget.SairaRegularTextView
                    android:id="@+id/tvRoad"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Immediate Ring Rd"
                    android:textColor="@color/white"
                    android:textFontWeight="300"
                    android:textSize="16sp"
                    app:layout_constraintStart_toStartOf="@id/tvDistance"
                    app:layout_constraintTop_toBottomOf="@id/tvDistance" />

                <ImageView
                    android:id="@+id/ivDivide"
                    android:layout_width="wrap_content"
                    android:layout_height="0dp"
                    android:layout_marginEnd="221dp"
                    android:src="@drawable/ic_line_maneuver"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.suprajit.uvcluster.ui.customWidget.SairaRegularTextView
                    android:id="@+id/tvTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="18dp"
                    android:layout_marginTop="15dp"
                    android:text="1Hr 42 min"
                    android:textColor="@color/white"
                    android:textFontWeight="500"
                    android:textSize="24sp"
                    app:layout_constraintStart_toEndOf="@id/ivDivide"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.suprajit.uvcluster.ui.customWidget.SairaRegularTextView
                    android:id="@+id/tvUnit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="km"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    app:layout_constraintStart_toStartOf="@id/tvTime"
                    app:layout_constraintTop_toBottomOf="@id/tvTime" />

                <com.suprajit.uvcluster.ui.customWidget.SairaRegularTextView
                    android:id="@+id/tvDistanceTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="6:4p pm"
                    android:textColor="@color/GlowBlue"
                    android:textSize="16sp"
                    app:layout_constraintStart_toEndOf="@id/tvUnit"
                    app:layout_constraintTop_toTopOf="@id/tvUnit" />
            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>


    </androidx.constraintlayout.widget.ConstraintLayout>


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clMapWithBallistic"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cvMap"
            android:layout_width="630dp"
            android:layout_height="479dp"
            android:layout_marginStart="19dp"
            android:layout_marginTop="23dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:strokeColor="@color/black">


            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/ivMap"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/image_map_ballistic" />

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_manuver_position"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cvTbtBallistic"
                    android:layout_width="570dp"
                    android:layout_height="90dp"
                    android:layout_marginBottom="13dp"
                    app:cardBackgroundColor="@color/blackTransparent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <ImageView
                            android:id="@+id/ivManeuverBallistic"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="31dp"
                            android:src="@drawable/ic_u_turn"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <com.suprajit.uvcluster.ui.customWidget.SairaRegularTextView
                            android:id="@+id/tvDistanceBallistic"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="15dp"
                            android:layout_marginTop="-10dp"
                            android:text="2.3 km"
                            android:textAllCaps="false"
                            android:textColor="@color/GlowBlue"
                            android:textFontWeight="500"
                            android:textSize="24sp"
                            app:layout_constraintStart_toEndOf="@id/ivManeuverBallistic"
                            app:layout_constraintTop_toTopOf="@id/ivManeuverBallistic"
                            app:textAllCaps="false" />

                        <com.suprajit.uvcluster.ui.customWidget.SairaRegularTextView
                            android:id="@+id/tvRoadBallistic"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Immediate Ring Rd"
                            android:textColor="@color/white"
                            android:textFontWeight="300"
                            android:textSize="16sp"
                            app:layout_constraintStart_toStartOf="@id/tvDistanceBallistic"
                            app:layout_constraintTop_toBottomOf="@id/tvDistanceBallistic" />

                        <ImageView
                            android:id="@+id/ivDivideBallistic"
                            android:layout_width="wrap_content"
                            android:layout_height="0dp"
                            android:layout_marginEnd="221dp"
                            android:src="@drawable/ic_line_maneuver"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <com.suprajit.uvcluster.ui.customWidget.SairaRegularTextView
                            android:id="@+id/tvTimeBallistic"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="18dp"
                            android:layout_marginTop="15dp"
                            android:text="1Hr 42 min"
                            android:textColor="@color/white"
                            android:textFontWeight="500"
                            android:textSize="24sp"
                            app:layout_constraintStart_toEndOf="@id/ivDivideBallistic"
                            app:layout_constraintTop_toTopOf="parent" />

                        <com.suprajit.uvcluster.ui.customWidget.SairaRegularTextView
                            android:id="@+id/tvUnitBallistic"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="km"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            app:layout_constraintStart_toStartOf="@id/tvTimeBallistic"
                            app:layout_constraintTop_toBottomOf="@id/tvTimeBallistic" />

                        <com.suprajit.uvcluster.ui.customWidget.SairaRegularTextView
                            android:id="@+id/tvDistanceTimeBallistic"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:text="6:4p pm"
                            android:textColor="@color/GlowBlue"
                            android:textSize="16sp"
                            app:layout_constraintStart_toEndOf="@id/tvUnitBallistic"
                            app:layout_constraintTop_toTopOf="@id/tvUnitBallistic" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                </com.google.android.material.card.MaterialCardView>


            </androidx.constraintlayout.widget.ConstraintLayout>


        </com.google.android.material.card.MaterialCardView>


        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="-170dp"
            android:src="@drawable/bg_ballistic"
            app:layout_constraintBottom_toBottomOf="@id/tvSpeedBallistic"
            app:layout_constraintStart_toStartOf="@id/tvSpeedBallistic"
            app:layout_constraintTop_toTopOf="@id/tvSpeedBallistic" />

        <com.suprajit.uvcluster.ui.customWidget.SairaRegularTextView
            android:id="@+id/tvWhKmLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="34dp"
            android:layout_marginTop="4dp"
            android:text="@string/whKm"
            android:textColor="@color/ballisticRed"
            app:layout_constraintStart_toEndOf="@id/cvMap"
            app:layout_constraintTop_toTopOf="@id/cvMap" />

        <TextView
            android:id="@+id/tvWhKm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/zen_dots_regular"
            android:text="42"
            android:textAllCaps="true"
            android:textColor="@color/white"
            android:textSize="27sp"
            app:layout_constraintStart_toStartOf="@id/tvWhKmLabel"
            app:layout_constraintTop_toBottomOf="@id/tvWhKmLabel" />

        <com.suprajit.uvcluster.ui.customWidget.SairaRegularTextView
            android:id="@+id/tvRec"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rec > 45"
            android:textColor="@color/ballisticGrey"
            app:layout_constraintStart_toStartOf="@id/tvWhKm"
            app:layout_constraintTop_toBottomOf="@id/tvWhKm" />

        <com.suprajit.uvcluster.ui.customWidget.SairaRegularTextView
            android:id="@+id/tvRangeLabelBallistic"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="320dp"
            android:text="@string/range"
            android:textAllCaps="true"
            android:textColor="@color/ballisticRed"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="@id/tvWhKmLabel"
            app:layout_constraintStart_toEndOf="@id/cvMap"
            app:layout_constraintTop_toTopOf="@id/tvWhKmLabel" />

        <TextView
            android:id="@+id/tvRangeBallistic"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/zen_dots_regular"
            android:text="123"
            android:textColor="@color/white"
            android:textSize="27sp"
            app:layout_constraintEnd_toEndOf="@id/tvRangeLabelBallistic"
            app:layout_constraintTop_toBottomOf="@id/tvRangeLabelBallistic" />


        <com.suprajit.uvcluster.ui.customWidget.SairaRegularTextView
            android:id="@+id/tvRangeBallisticUnit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="kms"
            android:textAllCaps="false"
            android:textColor="@color/ballisticGrey"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="@id/tvRangeBallistic"
            app:layout_constraintTop_toBottomOf="@id/tvRangeBallistic"
            app:textAllCaps="true" />

        <TextView
            android:id="@+id/tvSpeedBallistic"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="70dp"
            android:fontFamily="@font/aoi_mono_extended"
            android:text="085"
            android:textColor="@color/white"
            android:textSize="92sp"
            app:layout_constraintBottom_toBottomOf="@id/cvMap"
            app:layout_constraintStart_toEndOf="@id/cvMap"
            app:layout_constraintTop_toTopOf="@id/cvMap" />

        <com.suprajit.uvcluster.ui.customWidget.SairaRegularTextView
            android:id="@+id/tvSpeedBallisticUnit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="-36dp"
            android:text="@string/kmph"
            android:textColor="@color/white"
            android:textSize="18sp"
            app:layout_constraintEnd_toEndOf="@id/tvSpeedBallistic"
            app:layout_constraintStart_toStartOf="@id/tvSpeedBallistic"
            app:layout_constraintTop_toBottomOf="@id/tvSpeedBallistic" />


        <com.suprajit.uvcluster.ui.customWidget.SairaRegularTextView
            android:id="@+id/tvRide"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="34dp"
            android:layout_marginBottom="22sp"
            android:text="85 km"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="18sp"
            app:layout_constraintBottom_toBottomOf="@id/cvMap"
            app:layout_constraintStart_toEndOf="@id/cvMap"
            app:textAllCaps="false" />


        <com.suprajit.uvcluster.ui.customWidget.SairaRegularTextView
            android:id="@+id/tvRideLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ride"
            android:textAllCaps="true"
            android:textColor="@color/ballisticRed"
            app:layout_constraintEnd_toEndOf="@id/tvRide"
            app:layout_constraintStart_toStartOf="@id/tvRide"
            app:layout_constraintTop_toBottomOf="@id/tvRide" />

        <com.suprajit.uvcluster.ui.customWidget.SairaRegularTextView
            android:id="@+id/tvBallistic"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="164dp"
            android:text="@string/ballistic"
            android:textAllCaps="true"
            android:textColor="@color/ballisticRed"
            app:layout_constraintBottom_toBottomOf="@id/tvRideLabel"
            app:layout_constraintStart_toEndOf="@id/cvMap"
            app:layout_constraintTop_toTopOf="@id/tvRideLabel" />


        <ImageView
            android:id="@+id/ivBallistic"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_ballistic_new"
            app:layout_constraintBottom_toTopOf="@id/tvBallistic"
            app:layout_constraintEnd_toEndOf="@id/tvBallistic"
            app:layout_constraintStart_toStartOf="@id/tvBallistic" />

        <com.suprajit.uvcluster.ui.customWidget.SairaRegularTextView
            android:id="@+id/tvOdoLAbel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="301dp"
            android:text="@string/odo"
            android:textAllCaps="true"
            android:textColor="@color/ballisticRed"
            app:layout_constraintBottom_toBottomOf="@id/tvRideLabel"
            app:layout_constraintStart_toEndOf="@id/cvMap"
            app:layout_constraintTop_toTopOf="@id/tvRideLabel" />

        <com.suprajit.uvcluster.ui.customWidget.SairaRegularTextView
            android:id="@+id/tvODo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1289 km"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="18sp"
            app:layout_constraintBottom_toTopOf="@id/tvOdoLAbel"
            app:layout_constraintEnd_toEndOf="@id/tvOdoLAbel"
            app:layout_constraintStart_toStartOf="@id/tvOdoLAbel"
            app:textAllCaps="false" />

        <com.suprajit.uvcluster.ui.customWidget.SairaRegularTextView
            android:id="@+id/tvRegen"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="52dp"
            android:text="R5"
            android:textColor="@color/ballisticRed"
