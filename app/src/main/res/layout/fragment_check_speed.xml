<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.features.settings.debug.CheckSpeedFragment">

    <!-- 🔹 TOP BAR -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1F1F1F"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/backBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:src="@drawable/ic_back"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_margin="12dp"/>
	<TextView
            android:id="@+id/imeiText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Imei no: "
            android:textSize="30sp"
            android:textColor="#AAAAAA"/>
        <TextView
            android:id="@+id/ssidText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SSID: "
            android:textSize="30sp"
            android:textColor="#AAAAAA"/>	

    </LinearLayout>

    <!-- 🔹 MAIN CONTENT -->
    <LinearLayout
        android:id="@+id/mainContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2"
        android:background="#1F1F1F"
        android:layout_marginTop="150dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- ================= DOWNLOAD ================= -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvDownloadTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DOWNLOAD"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:textSize="30sp"/>



            <Button
                android:id="@+id/checkDownload"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Check Download"
                android:textSize="20sp"
                android:layout_marginTop="8dp"/>

            <TextView
                android:id="@+id/downloadText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="30sp"
                android:textColor="#AAAAAA"
                android:layout_marginTop="12dp"/>


        </LinearLayout>

        <!-- 🔹 Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#555555"/>

        <!-- ================= UPLOAD ================= -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvUploadTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="UPLOAD"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:textSize="30sp"/>

            <Button
                android:id="@+id/checkUpload"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Check Upload"
                android:textSize="20sp"
                android:layout_marginTop="8dp"/>
            <TextView
                android:id="@+id/uploadText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="30sp"
                android:textColor="#AAAAAA"
                android:layout_marginTop="12dp"/>




        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

